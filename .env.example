# Nex environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Required. Your OpenAI (or OpenAI-compatible) API key.
OPENAI_API_KEY=sk-your-key-here

# Optional. Point at any OpenAI-compatible provider (e.g. a proxy, Groq, Together).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Model to use for generation. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini
